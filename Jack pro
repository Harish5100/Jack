
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Harish — Product Designer & AI Maker</title>
<meta name="description" content="Personal portfolio — projects, skills and contact." />
<!-- Basic styling (mobile-first) -->
<style>
  :root{
    --bg:#0f1724; --card:#0b1220; --muted:#94a3b8; --accent:#ffb86b; --glass: rgba(255,255,255,0.04);
    --radius:12px; --maxw:1100px; font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,"Helvetica Neue",Arial;
  }
  *{box-sizing:border-box}
  html,body{height:100%}
  body{
    margin:0;background:linear-gradient(180deg,#071022 0%, #07132a 100%); color:#e6eef8;
    -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;
    padding:24px; display:flex; justify-content:center;
  }
  .site{width:100%; max-width:var(--maxw)}
  header{
    display:flex; gap:12px; align-items:center; justify-content:space-between;
    margin-bottom:18px;
  }
  .brand{display:flex; gap:12px; align-items:center}
  .logo{
    width:54px; height:54px; border-radius:12px; background:linear-gradient(135deg,#ffb86b,#ff7ab6);
    display:grid;place-items:center;font-weight:700;color:#081226;font-size:18px;
    box-shadow:0 6px 18px rgba(0,0,0,0.45);
  }
  nav{display:flex; gap:12px; align-items:center}
  nav a{color:var(--muted); text-decoration:none; font-weight:600; font-size:14px}
  .btn{background:var(--accent); color:#071226; padding:10px 14px; border-radius:10px; text-decoration:none; font-weight:700}
  main{display:grid; gap:22px}
  .hero{
    background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);
    padding:18px; border-radius:16px; box-shadow:0 6px 30px rgba(2,6,23,0.6); display:grid; gap:12px;
  }
  .hero-grid{display:grid; grid-template-columns: 1fr; gap:14px;}
  .title{font-size:20px; font-weight:800; letter-spacing:-0.4px}
  .subtitle{color:var(--muted); line-height:1.45}
  .hero-actions{display:flex; gap:10px; flex-wrap:wrap;}
  .cards{display:grid; gap:14px;}
  .card{background:var(--card); padding:14px; border-radius:12px; box-shadow: 0 4px 18px rgba(2,6,23,0.6)}
  .projects{display:grid; gap:12px}
  .project{display:flex; gap:12px; align-items:flex-start}
  .project-image{width:86px;height:64px;border-radius:8px;background:var(--glass);flex-shrink:0;display:grid;place-items:center;color:var(--muted)}
  .project-info h4{margin:0 0 6px 0}
  .tags{display:flex;gap:8px;flex-wrap:wrap}
  .tag{padding:6px 8px;border-radius:999px;background:rgba(255,255,255,0.03);font-size:12px;color:var(--muted)}
  .two-col{display:grid;grid-template-columns:1fr;gap:12px}
  footer{color:var(--muted); font-size:13px; text-align:center; padding:18px 0}
  /* Testimonials */
  .test-row{display:flex;gap:10px;flex-wrap:wrap}
  .pill{padding:8px 10px;border-radius:8px;background:rgba(255,255,255,0.02);font-size:13px}
  /* Contact */
  .contact-grid{display:grid;gap:8px}
  input, textarea{width:100%; padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.03); background:transparent;color:inherit}
  .muted{color:var(--muted);font-size:14px}
  /* Responsive */
  @media(min-width:880px){
    .hero-grid{grid-template-columns: 1fr 360px}
    .two-col{grid-template-columns: 1fr 360px}
    nav a{font-size:15px}
  }
</style>
</head>
<body>
  <div class="site">
    <header>
      <div class="brand">
        <div class="logo" id="logoText">H</div>
        <div>
          <div style="font-weight:800">Harish Kumar</div>
          <div class="muted" style="font-size:13px">Product Designer • AI Maker</div>
        </div>
      </div>
      <nav>
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#skills">Skills</a>
        <a href="#contact">Contact</a>
        <a class="btn" href="resume.pdf" download>Download Resume</a>
      </nav>
    </header>

    <main>
      <!-- HERO -->
      <section class="hero">
        <div class="hero-grid">
          <div>
            <div class="title">Hi — I'm Harish. I build AI-first product experiences.</div>
            <p class="subtitle">I combine product design and prompt engineering to help startups ship faster. I design interfaces, write AI prompts, and build SOPs that teams can reuse. Available for freelance projects and short-term contracts.</p>
            <div class="hero-actions">
              <a class="btn" href="#contact">Work with me</a>
              <a class="pill" href="#projects">See projects</a>
              <a class="pill" href="mailto:youremail@example.com?subject=Website%20Inquiry">Email me</a>
            </div>
            <div style="margin-top:12px; color:var(--muted); font-size:13px">Based in India • Open to remote work</div>
          </div>

          <aside class="card">
            <div style="font-weight:700">Quick stats</div>
            <div style="display:flex;gap:8px;margin-top:10px">
              <div style="flex:1">
                <div style="font-size:18px;font-weight:800">5+</div>
                <div class="muted" style="font-size:13px">Years experience</div>
              </div>
              <div style="flex:1">
                <div style="font-size:18px;font-weight:800">30+</div>
                <div class="muted" style="font-size:13px">Projects shipped</div>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <!-- ABOUT + PROJECTS -->
      <div class="two-col">
        <section class="card" id="about">
          <h3 style="margin-top:0">About</h3>
          <p class="muted">I help early-stage startups and agencies create product flows, design systems, and AI prompt templates that speed up execution. My workflow pairs Figma-like structure with prompt engineering so non-designers can generate drafts that are production-ready.</p>
          <div style="margin-top:12px" class="tags">
            <div class="tag">Product Design</div>
            <div class="tag">Prompt Engineering</div>
            <div class="tag">SaaS</div>
            <div class="tag">Figma</div>
          </div>
        </section>

        <section class="card" id="projects">
          <h3 style="margin-top:0">Select Projects</h3>
          <div class="projects">
            <article class="project">
              <div class="project-image">Img</div>
              <div class="project-info">
                <h4>AI Content Studio</h4>
                <div class="muted">A micro-SaaS that generates SEO outlines and short articles with a single prompt. I designed the UX & prompt flows.</div>
                <div style="margin-top:8px" class="tags">
                  <div class="tag">SaaS</div><div class="tag">Prompt Design</div>
                </div>
              </div>
            </article>

            <article class="project">
              <div class="project-image">Img</div>
              <div class="project-info">
                <h4>Agency SOP Pack</h4>
                <div class="muted">Packaged SOP templates + onboarding emails for digital agencies. Converts to a digital product.</div>
                <div style="margin-top:8px" class="tags">
                  <div class="tag">Templates</div><div class="tag">Operations</div>
                </div>
              </div>
            </article>

            <article class="project">
              <div class="project-image">Img</div>
              <div class="project-info">
                <h4>Product Landing Kit</h4>
                <div class="muted">Landing page templates and copy blocks optimized for conversions. I built components & test plan.</div>
                <div style="margin-top:8px" class="tags">
                  <div class="tag">Landing</div><div class="tag">Copy</div>
                </div>
              </div>
            </article>
          </div>
        </section>
      </div>

      <!-- SKILLS + TESTIMONIALS -->
      <section class="card" id="skills">
        <h3 style="margin-top:0">Skills & Tools</h3>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px">
          <div class="pill">UX Research</div>
          <div class="pill">Wireframing</div>
          <div class="pill">Figma</div>
          <div class="pill">Prompt Engineering</div>
          <div class="pill">HTML/CSS</div>
          <div class="pill">Gumroad</div>
        </div>

        <div style="margin-top:12px">
          <h4 style="margin:8px 0">Testimonials</h4>
          <div class="test-row">
            <div class="card" style="flex:1">
              <strong>Priya — Founder</strong>
              <div class="muted">"Harish delivered an onboarding flow that saved our team 10 hours/week."</div>
            </div>
            <div class="card" style="flex:1">
              <strong>Rahul — Head of Growth</strong>
              <div class="muted">"Clear, fast, and practical templates — integrated with our ops." </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CONTACT -->
      <section class="card" id="contact">
        <h3 style="margin-top:0">Contact</h3>
        <p class="muted">Available for freelance and contract work. Tell me about your project — timeline and budget help a lot.</p>

        <div class="contact-grid" style="margin-top:10px">
          <!-- This form uses mailto as there is no backend -->
          <form id="contactForm" onsubmit="return sendMail(event)">
            <input id="name" placeholder="Your name" required />
            <input id="email" type="email" placeholder="Your email" required />
            <input id="subject" placeholder="Subject (e.g., Project inquiry)" required />
            <textarea id="message" rows="5" placeholder="Brief message — what do you need?" required></textarea>
            <div style="display:flex;gap:8px;margin-top:8px">
              <button type="submit" class="btn" style="border:none">Send email</button>
              <a class="pill" href="mailto:youremail@example.com">Or email directly</a>
            </div>
          </form>
        </div>
      </section>

      <footer>
        © <span id="year"></span> Harish Kumar • <span class="muted">Built with ♥ and AI</span>
      </footer>
    </main>
  </div>

  <script>
    // small JS helpers
    document.getElementById('year').textContent = new Date().getFullYear();

    function sendMail(e){
      e.preventDefault();
      const name = encodeURIComponent(document.getElementById('name').value);
      const email = encodeURIComponent(document.getElementById('email').value);
      const subject = encodeURIComponent(document.getElementById('subject').value);
      const message = encodeURIComponent(document.getElementById('message').value + "\n\n— Sent from portfolio site");
      // create mailto link (opens user's mail app)
      const mailto = `mailto:youremail@example.com?subject=${subject}&body=Name:%20${name}%0AEmail:%20${email}%0A%0A${message}`;
      window.location.href = mailto;
      return false;
    }

    // quick replace initials in logo (optional)
    (function(){
      const initials = "H";
      const logo = document.getElementById('logoText');
      if(logo) logo.textContent = initials;
    })();
  </script>
</body>
</html>
